{
  "name": "keyshortcut",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "icons": "node scripts/download-icons.mjs",
    "dev": "node scripts/download-icons.mjs && react-router dev",
    "build": "node scripts/download-icons.mjs && node scripts/generate-sitemap.mjs && react-router build",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "lint": "eslint .",
    "preview": "react-router-serve ./build/server/index.js",
    "start": "react-router-serve ./build/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:perf": "vitest run src/test/performance.test.js",
    "test:perf:browser": "npx playwright test e2e/performance.spec.js",
    "deploy": "pnpm build && pnpm wrangler pages deploy build/client --project-name=keyshortcut --commit-dirty=true",
    "sync": "node scripts/shortcut-sync/run.mjs",
    "sync:dry": "node scripts/shortcut-sync/run.mjs --dry-run",
    "sync:health": "node scripts/shortcut-sync/run.mjs --health-check"
  },
  "dependencies": {
    "@react-router/node": "^7.13.1",
    "@react-router/serve": "^7.13.1",
    "@supabase/supabase-js": "^2.100.0",
    "isbot": "^5",
    "jspdf": "^4.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@google/genai": "^1.46.0",
    "@react-router/dev": "^7.13.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "cheerio": "^1.2.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fastest-levenshtein": "^1.0.16",
    "globals": "^16.5.0",
    "jsdom": "^29.0.0",
    "lucide-react": "^0.577.0",
    "pdf-parse": "^2.4.5",
    "simple-icons": "^16.11.0",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.0",
    "wrangler": "^4.77.0"
  }
}
