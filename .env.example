# Supabase (optional for build — only needed for `pnpm export`, `pnpm sync`, `pnpm add-app`)
# Build reads from committed JSON files in public/data/ — no credentials needed
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role (required for shortcut-sync write operations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini (required for AI-powered scraping in shortcut-sync)
GEMINI_API_KEY=your-gemini-api-key

# Cloudflare Web Analytics (optional — analytics disabled if empty)
VITE_CF_ANALYTICS_TOKEN=your-cf-analytics-token

# Google AdSense publisher ID (optional — ads disabled if empty)
VITE_ADSENSE_ID=ca-pub-your-id

# Mac App Store app ID (optional — uses placeholder URL if empty)
VITE_APP_STORE_ID=your-app-store-id

# Google Analytics 4 (optional — disabled if empty). Gated behind cookie consent.
VITE_GA4_ID=G-XXXXXXXXXX

# Microsoft Clarity (optional — heatmaps/recordings disabled if empty). Gated behind cookie consent.
VITE_CLARITY_ID=xxxxxxxxxx

# PostHog (optional — product analytics disabled if empty). Gated behind cookie consent.
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxx
VITE_POSTHOG_HOST=https://us.i.posthog.com
